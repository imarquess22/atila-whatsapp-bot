# ── Meta WhatsApp Cloud API ──────────────────────────────────────────────
# Meta for Developers → seu app → WhatsApp → API Setup
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
# Você mesmo inventa essa string; usa o MESMO valor ao configurar o Webhook na Meta
META_VERIFY_TOKEN=
# Meta for Developers → seu app → Settings → Basic → App Secret
META_APP_SECRET=

# ── Supabase (mesmo projeto do index.html) ──────────────────────────────
SUPABASE_URL=https://qtxglcprcuwucukablar.supabase.co
# Supabase → Settings → API → service_role secret (NUNCA usar a anon key aqui)
SUPABASE_SERVICE_KEY=

# ── Admin ────────────────────────────────────────────────────────────────
# Você mesmo inventa essa string; usada para chamar /api/admin-reset
ADMIN_SECRET=
# Você mesmo inventa essa string; usada pela telinha "Mensagens WhatsApp" do
# index.html para enviar respostas manuais (endpoint /api/enviar-manual)
PAINEL_WHATSAPP_SECRET=
# Número (com DDI, só dígitos) que recebe o aviso automático quando uma
# cliente pede "falar com atendente" no bot. Ex: 5511999999999
STUDIO_NOTIFICACAO_TELEFONE=
